# Turso Database
TURSO_DATABASE_URL=libsql://tu-database.turso.io
TURSO_AUTH_TOKEN=tu-token-write-aqui

# Security
CSRF_SECRET=32-chars-random-secret-string-minimo
IP_HASH_SALT=16-chars-random-salt-minimo
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=3600000

# Deadline (Colombia UTC-5)
FORM_DEADLINE=2025-08-08T23:59:59-05:00

# Build
NODE_ENV=development
