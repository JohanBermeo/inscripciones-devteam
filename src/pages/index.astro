---
import RegistrationForm from '../components/forms/RegistrationForm.astro';
import Layout from '../layouts/Layout.astro';
import { generateCsrfToken } from '../lib/security/csrf';

const locals = Astro.locals as { formOpen: boolean };
const formOpen = locals.formOpen ?? true;

const csrfToken = await generateCsrfToken();

Astro.cookies.set('csrf_token', csrfToken, {
  httpOnly: true,
  secure: import.meta.env.PROD,
  sameSite: 'strict',
  maxAge: 3600,
  path: '/',
});
---

<Layout title="Inscripción - DevTeam">
  <main>
    <header class="page-header">
      <div class="header">
        <h1>Formulario de Inscripción</h1>
        <p class="subtitle">DevTeam - Universidad Distrital</p>
        <p class="info-text">
          Completa todos los campos obligatorios (*) para enviar tu solicitud.
        </p>
        <span class="status-badge">Inscripciones Abiertas<span class="status-badge-dot"></span></span>
      </div>

      <div
        id="header-progress"
        class="header-progress"
        role="progressbar"
        aria-valuenow="1"
        aria-valuemin="0"
        aria-valuemax="4"
        aria-label="Progreso del formulario de inscripción"
      >
        <div id="header-progress-fill" class="header-progress-fill" style="width: 0%"></div>
      </div>
      <div id="step-announce" class="sr-only" aria-live="polite"></div>
    </header>

    <div class="page-inner">
      {formOpen ? (
        <RegistrationForm csrfToken={csrfToken} deadline="2025-08-08T23:59:59-05:00" />
      ) : (
        <section class="closed-message" role="alert">
          <h2>Inscripciones Cerradas</h2>
          <p>El período de inscripciones finalizó el <strong>8 de agosto de 2025</strong>.</p>
          <p>Gracias por tu interés en formar parte del DevTeam.</p>
        </section>
      )}
    </div>
  </main>
</Layout>

<style>
  .header {
    text-align: left;
    padding: 1.5rem 3rem 1rem;
  }

  h1 {
    font-size: 36px;
    margin: 0 0 0.25rem;
    color: var(--color-text-main);
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: var(--color-lime);
    color: var(--color-lime-dark);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    margin-top: 1rem;
    text-transform: uppercase;
  }

  .status-badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-lime-dark);
    animation: pulse-dot 1.8s ease infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.75); }
  }

  .subtitle {
    font-size: 20px;
    color: var(--color-text-secondary);
    margin: 0 0 0.5rem;
  }

  .info-text {
    font-size: 16px;
    color: var(--color-text-muted);
    margin: 0;
  }

  .header-progress {
    height: 3px;
    background: var(--color-border);
    margin-top: 1.5rem;
    overflow: hidden;
  }

  .header-progress-fill {
    height: 100%;
    background: var(--color-purple);
    width: 0%;
    transition: width 0.35s ease;
  }

  .page-inner {
    margin: 0 auto;
    padding: 5rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .closed-message {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error-border);
    border-radius: 0.75rem;
    color: var(--color-error-text);
  }

  .closed-message h2 {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
  }

  .closed-message p {
    margin: 0.25rem 0;
    font-size: 1rem;
  }

  /* ── Tablet (≤ 768px) ─────────────────────────────── */
  @media (max-width: 768px) {
    .header {
      padding: 1.25rem 1.5rem 0.75rem;
    }

    h1 {
      font-size: 28px;
    }

    .subtitle {
      font-size: 17px;
    }

    .info-text {
      font-size: 14px;
    }

    .page-inner {
      padding: 2.5rem 1.5rem;
    }
  }

  /* ── Mobile (≤ 480px) ─────────────────────────────── */
  @media (max-width: 480px) {
    .header {
      padding: 1rem 1rem 0.75rem;
    }

    h1 {
      font-size: 22px;
    }

    .subtitle {
      font-size: 15px;
    }

    .info-text {
      font-size: 13px;
    }

    .page-inner {
      padding: 1.5rem 1rem;
    }

    .closed-message {
      padding: 2rem 0.75rem;
    }
  }
</style>
